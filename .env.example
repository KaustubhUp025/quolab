# ── quolab configuration ───────────────────────────────────────────────────
# Copy to .env and fill in. All vars are prefixed QUOLAB_.

# --- Embeddings (default: local Qwen3-Embedding model — no API key, no rate limit) ---
# The default embedder runs on-device via sentence-transformers (pip install 'quolab[local]').
# It auto-uses the GPU when present (fp16) and falls back to CPU. First run downloads the
# model (~1.2 GB) to ~/.cache/huggingface.
QUOLAB_EMBEDDER=local                        # local (default) | gemini | hash
QUOLAB_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B # sentence-transformers id (local), OR gemini model id
QUOLAB_EMBED_DIM=1024                         # embedding dimension (Qwen3-Embedding-0.6B native = 1024)
QUOLAB_EMBED_CONCURRENCY=4                    # parallel embedding batches during indexing
#
# Opt-in hosted Gemini embedder instead: pip install 'quolab[gemini]', then set
#   QUOLAB_EMBEDDER=gemini, QUOLAB_EMBED_MODEL=gemini-embedding-001, QUOLAB_EMBED_DIM=768
#   QUOLAB_GEMINI_API_KEY=<key from https://aistudio.google.com/apikey>
# Note: the free tier caps embed_content at ~100 requests/min (each chunk ≈ 1 request).
QUOLAB_GEMINI_API_KEY=

# --- Vector store ---
QUOLAB_STORE=sqlite                     # sqlite (zero-infra default) | pgvector
QUOLAB_SQLITE_PATH=.quolab_cache/index.db
# Only used when QUOLAB_STORE=pgvector:
QUOLAB_PG_DSN=postgresql://user:pass@localhost:5432/quolab

# --- Source fetch (how repos are pulled for indexing) ---
QUOLAB_FETCH=git                        # git (shallow clone) | rest (GitLab API, read-only targets)
QUOLAB_GITLAB_URL=https://gitlab.com
QUOLAB_GITLAB_TOKEN=                    # PAT with read_api/read_repository (free tier)
QUOLAB_REPO_CACHE=.repos                # where shallow clones land

# --- Indexing behaviour ---
QUOLAB_MAX_FILE_BYTES=400000            # skip files larger than this
QUOLAB_CHUNK_MAX_LINES=120              # fallback line-window when tree-sitter has no grammar
QUOLAB_INCLUDE_GLOBS=**/*.py,**/*.go,**/*.java,**/*.ts,**/*.js,**/*.rb,**/*.rs,**/*.cs,**/*.kt

# --- Server ---
QUOLAB_HOST=0.0.0.0
QUOLAB_PORT=8080
QUOLAB_LOG_LEVEL=info
